# ===========================================
# ASTRA-X Environment Configuration
# ===========================================

# Database (SQLite for local, PostgreSQL for production)
# Local: sqlite:///./astra_x.db
# Render: postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./astra_x.db

# Environment
ENVIRONMENT=development

# API Keys (placeholder for future use)
OPENAI_API_KEY=sk-placeholder
TERMINAL3_API_KEY=t3-placeholder

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server
HOST=0.0.0.0
PORT=8000

# ML Model Cache Directory
MODEL_CACHE_DIR=./model_cache

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
